<Window x:Class="Techolics_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Width="800"
        Height="600"
        Icon="/assets/logo.png"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <!-- Define rows for layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="*" />
            <!-- Main Content -->
            <RowDefinition Height="Auto" />
            <!-- Footer (for time display) -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,0">
                <TextBlock Text="System Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            </Grid>
            
            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Edition: " FontWeight="Bold" Margin="0,0,5,0" />
                        <TextBlock x:Name="EditionTextBlock" Text="Sample Edition" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Username: " FontWeight="Bold" Margin="0,0,5,0" />
                        <TextBlock x:Name="UsernameTextBlock" Text="Sample Username" />
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Domain: " FontWeight="Bold" Margin="0,0,5,0" />
                            <TextBlock x:Name="DomainTextBlock" Text="Sample Domain" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Windows Version: " FontWeight="Bold" Margin="0,0,5,0" />
                            <TextBlock x:Name="WindowsVersionTextBlock" Text="10.0.19045" />
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid Grid.Column="1" Margin="0,0,0,0">
                    <TextBlock Text="Admin Privileges: " FontWeight="Bold" Margin="0,0,5,0" />
                    <Ellipse x:Name="AdminStatusEllipse" Width="15" Height="15" VerticalAlignment="Center" Fill="Green" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Header: System Details -->
        

        <!-- Main Content: Profile Selection and Buttons -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column: ListBox for Available Items -->
                <Grid Grid.Column="0" Margin="10,0">
                    <ListBox x:Name="AvailableItemsListBox" Margin="10">
                        <ListBoxItem>L1</ListBoxItem>
                        <ListBoxItem>L1+BL</ListBoxItem>
                        <ListBoxItem>L2</ListBoxItem>
                        <ListBoxItem>L2+BL</ListBoxItem>
                        <ListBoxItem>BL</ListBoxItem>
                    </ListBox>
                </Grid>

                <!-- Middle Column: Buttons -->
                <Grid Grid.Column="1" Margin="10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10">
                        <Button x:Name="AddButton" Content="Add" Height="40" Margin="0,5" Click="AddButton_Click" />
                        <Button x:Name="AddAllButton" Content="Add All" Height="40" Margin="0,5" Click="AddAllButton_Click" />
                        <Button x:Name="RemoveButton" Content="Remove" Height="40" Margin="0,5" Click="RemoveButton_Click" />
                        <Button x:Name="RemoveAllButton" Content="Remove All" Height="40" Margin="0,5" Click="RemoveAllButton_Click" />
                    </StackPanel>
                </Grid>

                <!-- Right Column: ListBox for Selected Items -->
                <Grid Grid.Column="2" Margin="10,0">
                    <ListBox x:Name="SelectedItemsListBox" Margin="10" />
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,0,0">
                    <Button Content="Audit" Width="100" Margin="0,0,0,10" Click="AuditButton_Click" />
                </Grid>
                <Grid Grid.Column="1" Margin="0,0,0,0">
                    <Button Content="Config" Width="100" Click="ConfigButton_Click" />
                </Grid>
            </Grid>
        </Grid>


        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Label -->
            <TextBlock Grid.Column="0" Text="Current Time: " FontWeight="Bold" VerticalAlignment="Center" />

            <!-- Value -->
            <TextBlock Grid.Column="1" x:Name="CurrentTimeTextBlock" VerticalAlignment="Center" Margin="5,0,0,0" Text="12:00:00 PM" />
        </Grid>

    </Grid>
</Window>
