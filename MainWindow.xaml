<Window x:Class="Techolics_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Techolics_" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
	<Grid>
		<!-- Define two rows: one for the navigation bar, one for the content -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Navigation Bar -->
			<RowDefinition Height="*"/>
			<!-- Content Area -->
		</Grid.RowDefinitions>

		<!-- Navigation Bar -->
		<Menu Grid.Row="0">
			<MenuItem Header="File">
				<MenuItem Header="New"/>
				<MenuItem Header="Open"/>
				<MenuItem Header="Save"/>
				<Separator/>
				<MenuItem Header="Exit"/>
			</MenuItem>
			<MenuItem Header="Edit">
				<MenuItem Header="Undo"/>
				<MenuItem Header="Redo"/>
				<Separator/>
				<MenuItem Header="Copy"/>
				<MenuItem Header="Paste"/>
			</MenuItem>
			<MenuItem Header="View">
				<MenuItem Header="Zoom In"/>
				<MenuItem Header="Zoom Out"/>
			</MenuItem>
			<MenuItem Header="Tools">
				<MenuItem Header="Options"/>
			</MenuItem>
			<MenuItem Header="Export"/>
			<MenuItem Header="Import"/>
		</Menu>

		<!-- Content Area with Three Columns -->
		<Grid Grid.Row="1" Margin="5">
			<!-- Define three columns -->
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*"/>
				<!-- Explorer -->
				<ColumnDefinition Width="3*"/>
				<!-- Display Content -->
				<ColumnDefinition Width="2*"/>
				<!-- Plain Text -->
			</Grid.ColumnDefinitions>

			<!-- First Column: Explorer -->
			<TreeView Grid.Column="0" Background="#f5f5f5" BorderBrush="#dcdcdc" BorderThickness="1">
				<TreeViewItem Header="Folder 1">
					<TreeViewItem Header="File 1.1"/>
					<TreeViewItem Header="File 1.2"/>
				</TreeViewItem>
				<TreeViewItem Header="Folder 2">
					<TreeViewItem Header="File 2.1"/>
				</TreeViewItem>
				<TreeViewItem Header="Folder 3"/>
			</TreeView>

			<!-- Second Column: Display Content -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="4*"/>
					<!-- Data Grid -->
					<RowDefinition Height="*"/>
					<!-- Plain Text Box -->
				</Grid.RowDefinitions>

				<DataGrid x:Name="myDataGrid" Grid.Row="0" Background="#ffffff" BorderBrush="#dcdcdc" BorderThickness="1"
          AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False">
					<DataGrid.Columns>
						<DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="*" />
						<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
						<DataGridTextColumn Header="Current" Binding="{Binding Current}" Width="*" />
						<DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
					</DataGrid.Columns>
				</DataGrid>




				<Grid Grid.Row="1" Margin="5">
					<!-- Define three columns -->
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="3*"/>
						<!-- Explorer -->
						<ColumnDefinition Width="1*"/>
						<!-- Display Content -->
					</Grid.ColumnDefinitions>

					<Border Grid.Column="0" BorderBrush="#dcdcdc" BorderThickness="1" CornerRadius="0" Padding="10" Background="#f9f9f9">
						<StackPanel>
							<!-- Heading -->
							<TextBlock Text="Logs" FontWeight="Bold" FontSize="16" Margin="0,0,0,0" />

							<!-- Black Line Separator -->
							<Rectangle Height="1" Fill="Black" Margin="0,0,0,10" />

							<!-- Content -->
							<TextBlock TextWrapping="Wrap" FontSize="14" FontFamily="Consolas">
								This is the detail section where descriptive information can be displayed.
							</TextBlock>
						</StackPanel>
					</Border>
					<Border Grid.Column="1" BorderBrush="#dcdcdc" BorderThickness="1" CornerRadius="0" Padding="10" Background="#f9f9f9">
						<Grid>
							<!-- Define three rows of equal height -->
							<Grid.RowDefinitions>
								<RowDefinition Height="*"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<!-- Buttons -->
							<Button Grid.Row="0" Content="Config" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
							<Button Grid.Row="1" Content="Config All" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
							<Button Grid.Row="2" Content="Edit" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
						</Grid>
					</Border>
				</Grid>

			</Grid>

			<!-- Third Column: Detail Section -->
			<Border Grid.Column="2" BorderBrush="#dcdcdc" BorderThickness="1" CornerRadius="5" Padding="10" Background="#f9f9f9">
				<StackPanel>
					<!-- Heading -->
					<TextBlock Text="Details" FontWeight="Bold" FontSize="16" Margin="0,0,0,0" />

					<!-- Black Line Separator -->
					<Rectangle Height="1" Fill="Black" Margin="0,0,0,10" />

					<!-- Content -->
					<TextBlock TextWrapping="Wrap" FontSize="14" FontFamily="Consolas">
						This is the detail section where descriptive information can be displayed.
					</TextBlock>
				</StackPanel>
			</Border>
		</Grid>
	</Grid>
</Window>
