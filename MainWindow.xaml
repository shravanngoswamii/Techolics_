<Window x:Class="Techolics_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Width="800"
        Height="600"
        Icon="/assets/logo.png"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <!-- Define rows for layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="*" />
            <!-- Main Content -->
            <RowDefinition Height="Auto" />
            <!-- Footer (for time display) -->
        </Grid.RowDefinitions>

        <!-- Header: System Details -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <TextBlock Text="System Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Username: " FontWeight="Bold"/>
                <TextBlock x:Name="UsernameTextBlock"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Windows Version: " FontWeight="Bold"/>
                <TextBlock x:Name="WindowsVersionTextBlock"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Edition: " FontWeight="Bold"/>
                <TextBlock x:Name="EditionTextBlock"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Domain: " FontWeight="Bold"/>
                <TextBlock x:Name="DomainTextBlock"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Admin Privileges: " FontWeight="Bold"/>
                <Ellipse x:Name="AdminStatusEllipse" Width="15" Height="15" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content: Profile Selection and Buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Profile Selection -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Select Profiles" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <CheckBox x:Name="L1CheckBox" Content="L1" Margin="0,0,0,5"/>
                <CheckBox x:Name="L1BLCheckBox" Content="L1+BL" Margin="0,0,0,5"/>
                <CheckBox x:Name="L2CheckBox" Content="L2" Margin="0,0,0,5"/>
                <CheckBox x:Name="L2BLCheckBox" Content="L2+BL" Margin="0,0,0,5"/>
                <CheckBox x:Name="BLCheckBox" Content="BL" Margin="0,0,0,5"/>
                <CheckBox x:Name="SelectAllCheckBox" Content="Select All" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Vertical Separator -->
            <Separator Grid.Column="1" Width="1" Background="Gray"/>

            <!-- Buttons -->
            <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Top">
                <Button Content="Audit" Width="100" Margin="0,0,0,10" Click="AuditButton_Click"/>
                <Button Content="Config" Width="100" Click="ConfigButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Footer: Current Time Display -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Current Time: " FontWeight="Bold"/>
            <TextBlock x:Name="CurrentTimeTextBlock" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
