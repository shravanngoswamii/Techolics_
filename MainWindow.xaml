<Window x:Class="Techolics_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Techolics_" Height="600" Width="1000" Icon="/assets/logo.png"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- Define two rows: one for the navigation bar, one for the content -->
        <Grid.RowDefinitions>
            <!-- Navigation Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="New"/>
                <MenuItem Header="Open"/>
                <MenuItem Header="Save"/>
                <Separator/>
                <MenuItem Header="Exit"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo"/>
                <MenuItem Header="Redo"/>
                <Separator/>
                <MenuItem Header="Copy"/>
                <MenuItem Header="Paste"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Zoom In"/>
                <MenuItem Header="Zoom Out"/>
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Options"/>
            </MenuItem>
            <MenuItem Header="Export"/>
            <MenuItem Header="Import"/>
        </Menu>

        <!-- Content Area with Three Columns -->
        <Grid Grid.Row="1" Margin="3">
            <!-- Define three columns -->
            <Grid.ColumnDefinitions>
                <!-- Explorer -->
                <ColumnDefinition Width="1*"/>
                <!-- Display Content -->
                <ColumnDefinition Width="3*"/>
                <!-- Details -->
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- First Column: Policy Explorer -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Navigation Bar -->
                    <RowDefinition Height="*"/>
                    <!-- Content Area -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,0,0,0">
                    <!-- Heading -->
                    <TextBlock Text="Policy Explorer" FontWeight="Bold" Background="#f5f5f5" FontSize="16" Margin="0,0,0,0" />
                </Grid>

                <Grid Grid.Row="1">
                    <TreeView x:Name="policyTreeView" Background="#f5f5f5" BorderBrush="#dcdcdc" BorderThickness="1"
                              SelectedItemChanged="PolicyTreeView_SelectedItemChanged">
                        <TreeViewItem Header="Account Policies">
                            <TreeViewItem Header="1.1 Password Policy" Tag="1.1" />
                            <TreeViewItem Header="1.2 Account Lockout Policy" Tag="1.2" />
                        </TreeViewItem>
                        <TreeViewItem Header="Local Policies">
                            <TreeViewItem Header="2.1 Audit Policy" Tag="2.1" />
                            <TreeViewItem Header="2.2 User Rights Assignment" Tag="2.2" />
                        </TreeViewItem>
                    </TreeView>
                </Grid>
            </Grid>

            <!-- Second Column: Display Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- Location-->
                    <RowDefinition Height="22"/>
                    <!-- Data Grid -->
                    <RowDefinition Height="4*"/>
                    <!-- Plain Text Box -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock x:Name="navigationTextBlock" Text="Path" FontWeight="Bold" FontSize="16" Margin="5,0,0,0" />
                </Grid>

                <DataGrid x:Name="myDataGrid" Grid.Row="1" Background="#ffffff" BorderBrush="#dcdcdc" BorderThickness="1"
                          AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" 
                          SelectionChanged="MyDataGrid_SelectionChanged" 
                           IsReadOnly="True"
                          SelectionMode="Extended">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="*" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Current" Binding="{Binding Current}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="5,5,5,5">
                    <!-- Define two columns -->
                    <Grid.ColumnDefinitions>
                        <!-- Logs-->
                        <ColumnDefinition Width="3*"/>
                        <!-- Display Content -->
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <!-- Heading -->
                            <RowDefinition Height="Auto"/>
                            <!-- Content Area -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="10,0,0,0">
                            <!-- Heading -->
                            <TextBlock Text="Logs" FontWeight="Bold" Background="#f5f5f5" FontSize="16" Margin="0,0,0,0" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="5,0,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="14" FontFamily="Consolas">
                                This is the detail section where descriptive information can be displayed.
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1">
                        <!-- Define three rows of equal height -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Buttons -->
                        <Button Grid.Row="0" Content="Config" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        <Button Grid.Row="1" Content="Config All" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        <Button Grid.Row="2" Content="Edit" Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                    </Grid>
                </Grid>
            </Grid>

            <!-- Third Column: Detail Section -->
            <Border Grid.Column="2" BorderBrush="#dcdcdc" BorderThickness="1" CornerRadius="5" Padding="10" Background="#f9f9f9">
                <StackPanel>
                    <!-- Heading -->
                    <TextBlock Text="Details" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                    <!-- Content -->
                    <TextBlock x:Name="detailsTextBlock" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas">
                        Select rows to view details.
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
