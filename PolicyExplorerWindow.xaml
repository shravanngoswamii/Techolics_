<Window
    x:Class="Techolics_.PolicyExplorerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Policy Explorer"
    Width="1000"
    Height="600"
    Icon="/assets/logo.png"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <!--  Define two rows: one for the navigation bar, one for the content  -->
        <Grid.RowDefinitions>
            <!--  Navigation Bar  -->
            <RowDefinition Height="Auto" />
            <!--  Content Area  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Navigation Bar  -->
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="New" />
                <MenuItem Header="Open" />
                <MenuItem Header="Save" />
                <Separator />
                <MenuItem Header="Exit" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" />
                <MenuItem Header="Redo" />
                <Separator />
                <MenuItem Header="Copy" />
                <MenuItem Header="Paste" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Zoom In" />
                <MenuItem Header="Zoom Out" />
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Options" />
            </MenuItem>
            <MenuItem Header="Export" />
            <MenuItem Header="Import" />
        </Menu>

        <!--  Content Area with Resizable Columns  -->
        <Grid Grid.Row="1" Margin="3">
            <!--  Define columns including GridSplitters  -->
            <Grid.ColumnDefinitions>
                <!--  Column 0: Policy Explorer  -->
                <ColumnDefinition Width="1*" />
                <!--  Column 1: GridSplitter  -->
                <ColumnDefinition Width="5" />
                <!--  Column 2: Display Content  -->
                <ColumnDefinition Width="3*" />
                <!--  Column 3: GridSplitter  -->
                <ColumnDefinition Width="5" />
                <!--  Column 4: Details  -->
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!--  First Column: Policy Explorer  -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Navigation Bar  -->
                    <RowDefinition Height="*" />
                    <!--  Content Area  -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,0,0,0">
                    <!--  Heading  -->
                    <TextBlock
                        Margin="0,0,0,0"
                        Background="#f5f5f5"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Policy Explorer" />
                </Grid>

                <Grid Grid.Row="1">
                    <TreeView
                        x:Name="policyTreeView"
                        Background="#f5f5f5"
                        BorderBrush="#dcdcdc"
                        BorderThickness="1">
                        <!--  TreeViewItems will be added dynamically in code  -->
                    </TreeView>
                </Grid>
            </Grid>

            <!--  GridSplitter between Column 0 and Column 2  -->
            <GridSplitter
                Grid.Column="1"
                Width="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Gray"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True" />

            <!--  Second Column: Display Content  -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!--  Location  -->
                    <RowDefinition Height="22" />
                    <!--  Data Grid  -->
                    <RowDefinition Height="4*" />
                    <!--  GridSplitter  -->
                    <RowDefinition Height="5" />
                    <!--  Plain Text Box  -->
                    <RowDefinition Height="*" />
                    <!--  Buttons  -->
                    <RowDefinition Height="50" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock
                        x:Name="navigationTextBlock"
                        Margin="5,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Path" />
                </Grid>

                <DataGrid
                    x:Name="myDataGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    Background="#ffffff"
                    BorderBrush="#dcdcdc"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    HeadersVisibility="Column"
                    IsReadOnly="False"
                    SelectionMode="Extended">

                    <DataGrid.Columns>
                        <!--  Add CheckBox column for selection  -->
                        <DataGridCheckBoxColumn
                            Width="Auto"
                            Binding="{Binding IsSelected, Mode=TwoWay}"
                            IsReadOnly="False">
                            <DataGridCheckBoxColumn.Header>
                                <CheckBox
                                    x:Name="SelectAllCheckBox"
                                    Click="SelectAllCheckBox_Click"
                                    Content="All" />
                            </DataGridCheckBoxColumn.Header>
                        </DataGridCheckBoxColumn>

                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding ID}"
                            Header="ID"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding Profile}"
                            Header="Profile"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Name}"
                            Header="Name"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding Current}"
                            Header="Current"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding Status}"
                            Header="Status"
                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>


                <GridSplitter
                    Grid.Row="2"
                    Height="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Gray"
                    ResizeBehavior="PreviousAndNext"
                    ResizeDirection="Rows"
                    ShowsPreview="True" />

                <Grid Grid.Row="3" Margin="5,5,5,5">
                    <Grid.RowDefinitions>
                        <!--  Heading  -->
                        <RowDefinition Height="Auto" />
                        <!--  Content Area  -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,0,0,0">
                        <!--  Heading  -->
                        <TextBlock
                            Margin="0,0,0,0"
                            Background="#f5f5f5"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Logs" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="5,0,0,0">
                        <TextBox
                            x:Name="logsTextBox"
                            AcceptsReturn="True"
                            Background="#f5f5f5"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            FontSize="14"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto">
                            This is the logs section where logs can be displayed.
                        </TextBox>
                    </Grid>
                </Grid>
                <Grid Grid.Row="4" Margin="5,5,5,5">

                    <!--  Update Column Definitions to include Revert Button  -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Buttons  -->
                    <Button
                        x:Name="AuditButton"
                        Grid.Column="0"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="AuditButton_Click"
                        Content="Audit" />
                    <Button
                        x:Name="AuditAllButton"
                        Grid.Column="1"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="AuditAllButton_Click"
                        Content="Audit All" />

                    <Button
                        x:Name="ConfigButton"
                        Grid.Column="2"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="ConfigButton_Click"
                        Content="Config" />

                    <Button
                        x:Name="ConfigAllButton"
                        Grid.Column="3"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="ConfigAllButton_Click"
                        Content="Config All" />

                    <Button
                        x:Name="EditButton"
                        Grid.Column="4"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="EditButton_Click"
                        Content="Edit" />

                    <!--  Add Revert Button  -->
                    <Button
                        x:Name="RevertButton"
                        Grid.Column="5"
                        Margin="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="RevertButton_Click"
                        Content="Revert" />

                </Grid>
            </Grid>

            <!--  GridSplitter between Column 2 and Column 4  -->
            <GridSplitter
                Grid.Column="3"
                Width="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Gray"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True" />

            <!--  Third Column: Detail Section  -->
            <Border
                Grid.Column="4"
                Padding="10"
                Background="#f9f9f9"
                BorderBrush="#dcdcdc"
                BorderThickness="1"
                CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  Heading  -->
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Details" />

                        <!--  Content  -->
                        <TextBlock
                            x:Name="detailsTextBlock"
                            FontFamily="Consolas"
                            FontSize="14"
                            TextWrapping="Wrap">
                            Select rows to view details.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>