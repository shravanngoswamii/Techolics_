<ui:FluentWindow
    x:Class="Techolics_.pages.SplashScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Welcome - Techolics_"
    Width="600"
    Height="400"
    Icon="/assets/logo.png"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Grid>
        <Image Source="/assets/logo.png" Width="200" Height="200" Margin="200,70,200,130"  />

        <TextBlock
            x:Name="DynamicText"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,180,0,0"
            FontFamily="Bell MT"
            FontSize="36" />
    </Grid>
</ui:FluentWindow>
