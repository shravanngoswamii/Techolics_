<Window x:Class="Techolics_.pages.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplashScreen" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ShowInTaskbar="False" Background="#06142c">

    <Grid>
        <Border BorderBrush="#3090ff" BorderThickness="5" HorizontalAlignment="Center" Height="108" VerticalAlignment="Center" Width="254"/>
        <Border BorderBrush="#3090ff" BorderThickness="4" HorizontalAlignment="Center" Height="70" VerticalAlignment="Center" Width="200"/>
        <TextBlock x:Name="DynamicText" FontSize="36" Foreground="#3090ff" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                    />
    </Grid>
</Window>
