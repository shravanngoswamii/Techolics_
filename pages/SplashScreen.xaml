<Window x:Class="Techolics_.pages.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplashScreen" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ShowInTaskbar="False" Background="#06142c">

    <Grid>
        <Image Source="/assets/logo.png" Width="200" Height="200" Margin="200,70,200,130"  />
        <TextBlock x:Name="DynamicText" FontSize="36" Foreground="#3090ff" 
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,273,0,0" 
                    />
    </Grid>
</Window>
