<?xml version="1.0" encoding="utf-8" ?>
<CIS_Benchmark>
    <Section id="1" title="Account Policies">
        <Section id="1.1" title="Password Policy">
            <Policy
                id="1.1.1"
                mode="Automated"
                profile="L1"
                title="Enforce password history"
                value_type="Integer">
                <DefaultValue domain="24" standalone="0" />
                <ValueConstraints>
                    <RequiredValue operator="greater_or_equal" value="24" />
                </ValueConstraints>
                <Implementation>
                    <Registry>
                        <Key>HKEY_LOCAL_MACHINE\Software\Policies\Microsoft\Windows\CurrentVersion\Policies\System</Key>
                        <ValueName>EnforcePasswordHistory</ValueName>
                        <ValueType>DWORD</ValueType>
                    </Registry>
                    <Secedit>
                        <TemplateSetting>PasswordHistorySize = %Value%</TemplateSetting>
                    </Secedit>
                    <GroupPolicy>
                        <PolicyPath>Computer Configuration\Policies\Windows Settings\Security Settings\Account Policies\Password Policy</PolicyPath>
                        <PolicyName>Enforce password history</PolicyName>
                    </GroupPolicy>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.2"
                mode="Automated"
                profile="L1"
                title="Maximum password age"
                value_type="Integer">
                <DefaultValue value="42" />
                <ValueConstraints>
                    <RequiredValue operator="less_or_equal" value="365" />
                    <RequiredValue operator="not_equal" value="0" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>MaximumPasswordAge = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.3"
                mode="Automated"
                profile="L1"
                title="Minimum password age"
                value_type="Integer">
                <DefaultValue domain="1" standalone="0" />
                <ValueConstraints>
                    <RequiredValue operator="greater_or_equal" value="1" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>MinimumPasswordAge = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.4"
                mode="Automated"
                profile="L1"
                title="Minimum password length"
                value_type="Integer">
                <DefaultValue domain="7" standalone="0" />
                <ValueConstraints>
                    <RequiredValue operator="greater_or_equal" value="14" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>MinimumPasswordLength = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.5"
                mode="Automated"
                profile="L1"
                title="Password must meet complexity requirements"
                value_type="Boolean">
                <DefaultValue domain="true" standalone="false" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="true" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>PasswordComplexity = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.6"
                mode="Automated"
                profile="L1"
                title="Relax minimum password length limits"
                value_type="Boolean">
                <DefaultValue value="disabled" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="enabled" />
                </ValueConstraints>
                <Implementation>
                    <Registry>
                        <Key>HKLM\System\CurrentControlSet\Control\SAM</Key>
                        <ValueName>RelaxMinimumPasswordLengthLimits</ValueName>
                        <ValueType>DWORD</ValueType>
                    </Registry>
                </Implementation>
            </Policy>
            <Policy
                id="1.1.7"
                mode="Automated"
                profile="L1"
                title="Store passwords using reversible encryption"
                value_type="Boolean">
                <DefaultValue value="disabled" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="disabled" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>ClearTextPassword = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
        </Section>
        <!--
            // TO-DO
            XAML data need depend-on value for Account policies as Reset account lockout counter after policy requires Account Lockout duration to be configured
        -->
        <Section id="1.2" title="Account Lockout Policy">
            <Policy
                id="1.2.1"
                mode="Automated"
                profile="L1"
                title="Account lockout duration"
                value_type="Integer">
                <DefaultValue value="10" />
                <ValueConstraints>
                    <RequiredValue operator="greater_or_equal" value="15" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>LockoutDuration = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.2.2"
                mode="Automated"
                profile="L1"
                title="Account lockout threshold"
                value_type="Integer">
                <DefaultValue value="10" />
                <ValueConstraints>
                    <RequiredValue operator="less_or_equal" value="5" />
                    <RequiredValue operator="not_equal" value="0" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>LockoutBadCount = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.2.3"
                mode="Manual"
                profile="L1"
                title="Allow Administrator account lockout"
                value_type="Boolean">
                <DefaultValue value="disabled" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="enabled" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>AllowAdministratorLockout = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="1.2.4"
                mode="Automated"
                profile="L1"
                title="Reset account lockout counter after"
                value_type="Integer">
                <DefaultValue value="10" />
                <ValueConstraints>
                    <RequiredValue operator="greater_or_equal" value="15" />
                </ValueConstraints>
                <Implementation>
                    <Secedit>
                        <TemplateSetting>ResetLockoutCount = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
        </Section>
    </Section>
    <Section id="2" title="Local Policies">
        <Section id="2.1" title="Audit Policy" />
        <Section id="2.2" title="User Rights Assignment">
            <Policy
                id="2.2.1"
                mode="Automated"
                profile="L1"
                title="Access Credential Manager as a trusted caller"
                value_type="String">
                <DefaultValue value="No one" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="No one" />
                </ValueConstraints>
                <Implementation>
                    <Secedit section="Privilege Rights">
                        <TemplateSetting>SeTrustedCredManAccessPrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.2"
                mode="Automated"
                profile="L1"
                title="Access this computer from the network"
                value_type="String">
                <DefaultValue value="Administrators, Backup Operators, Everyone, Users." />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, Remote Desktop Users" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeNetworkLogonRight = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.3"
                mode="Automated"
                profile="L1"
                title="Act as part of the operating system"
                value_type="String">
                <DefaultValue value="No One" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="No One" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeTcbPrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.4"
                mode="Automated"
                profile="L1"
                title="Adjust memory quotas for a process"
                value_type="String">
                <DefaultValue value="Administrators, LocalService, NetworkService" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, LocalService, NetworkService" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeIncreaseQuotaPrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.5"
                mode="Automated"
                profile="L1"
                title="Allow log on locally"
                value_type="String">
                <DefaultValue value="Administrators, Backup Operators, Guest, Users" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, Users" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeInteractiveLogonRight = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.6"
                mode="Automated"
                profile="L1"
                title="Allow log on through Remote Desktop Services"
                value_type="String">
                <DefaultValue value="Administrators, Remote Desktop Users" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, Remote Desktop Users" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeRemoteInteractiveLogonRight = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.7"
                mode="Automated"
                profile="L1"
                title="Back up files and directories"
                value_type="String">
                <DefaultValue value="Administrators, Backup Operators" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeBackupPrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.8"
                mode="Automated"
                profile="L1"
                title="Change the system time"
                value_type="String">
                <DefaultValue value="Administrators, LocalService" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, LocalService" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeSystemtimePrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
            <Policy
                id="2.2.9"
                mode="Automated"
                profile="L1"
                title="Change the time zone"
                value_type="String">
                <DefaultValue value="Administrators, LocalService, Users" />
                <ValueConstraints>
                    <RequiredValue operator="equal" value="Administrators, LocalService, Users" />
                </ValueConstraints>
				<Implementation>
					<Secedit section="Privilege Rights">
                        <TemplateSetting>SeTimeZonePrivilege = %Value%</TemplateSetting>
                    </Secedit>
                </Implementation>
            </Policy>
        </Section>
    </Section>
</CIS_Benchmark>
