<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <PublishSingleFile>true</PublishSingleFile> <!-- Enable single file publishing -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier> <!-- Specify the target platform -->
    <SelfContained>true</SelfContained> <!-- Optional: Make the app self-contained (includes .NET runtime) -->
  </PropertyGroup>

  <ItemGroup>
    <None Remove="assets\logo.png" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="data\CIS_Benchmark_Documentation.xaml" />
    <Page Remove="data\CIS_Benchmark_Values.xaml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="data\CIS_Benchmark_Documentation.xaml">
      <Generator>MSBuild:Compile</Generator>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="data\CIS_Benchmark_Values.xaml">
      <Generator>MSBuild:Compile</Generator>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Extended.Wpf.Toolkit" Version="4.6.1" />
    <PackageReference Include="Microsoft.PowerShell.SDK" Version="7.4.6" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Management" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="assets\logo.png" />
  </ItemGroup>

</Project>
