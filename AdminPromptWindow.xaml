<Window x:Class="Techolics_.AdminPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administrative Privileges Required"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Administrative privileges are required to use this feature. Would you like to restart the application with administrative privileges?" 
                   TextWrapping="Wrap" Margin="0,0,0,10"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="YesButton" Content="Yes" Width="75" Margin="0,0,10,0" Click="YesButton_Click"/>
            <Button x:Name="NoButton" Content="No" Width="75" Click="NoButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
